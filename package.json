{
  "name": "keyless-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,js,json,md,yaml}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.39.0",
    "@eslint/js": "^9.39.0",
    "typescript-eslint": "^8.35.0",
    "prettier": "^3.8.0",
    "turbo": "^2.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0"
  },
  "lint-staged": {
    "*.{ts,js}": ["eslint --fix", "prettier --write"],
    "*.{json,md,yaml}": ["prettier --write"]
  }
}
